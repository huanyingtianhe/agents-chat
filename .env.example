# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-string
NEXTAUTH_URL=https://localhost:3010

# Azure AD (Microsoft Entra ID) — optional, leave CLIENT_ID empty to disable
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Dev Tunnel used by start.ps1 when not using -Cloudflare
DEV_TUNNEL_NAME=
DEV_TUNNEL_URL=

# Admin credentials (used for local username/password login)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Comma-separated emails treated as admin (for Azure AD users)
ADMIN_EMAILS=

# Azure Relay — required for relay agents and node probing/discovery
# Set RELAY_SEND_CONNECTION_STRING to enable relay agent connections.
# Set RELAY_SUBSCRIPTION_ID + RELAY_RESOURCE_GROUP to let generated setup ZIPs
# create/update/delete relay hybrid connections. Add RELAY_NAMESPACE to enable
# auto-discovery of relay nodes via the Azure ARM API.
RELAY_SEND_CONNECTION_STRING=
# Key Vault defaults embedded into newly downloaded node setup ZIPs.
# Leave blank if you pass RELAY_CONNECTION_STRING directly to setup-node.ps1.
# After changing setup ZIP values, restart or redeploy the app and download a new copilot-node-setup.zip.
RELAY_KEY_VAULT_NAME=
RELAY_KEY_VAULT_SECRET_NAME=
RELAY_SUBSCRIPTION_ID=
RELAY_RESOURCE_GROUP=
RELAY_NAMESPACE=
